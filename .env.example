# .env.example
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai

# ── App Configuration ──
APP_PORT=3000

# ── PostgreSQL Database ──
DB_HOST=postgres
DB_PORT=5432
DB_NAME=siakad_db
DB_USER=siakad_user
DB_PASSWORD=change_me_db_password

# ── MinIO Object Storage ──
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=change_me_access_key
MINIO_SECRET_KEY=change_me_secret_key
MINIO_BUCKET=student-documents
